<?xml version="1.0" ?>

<robot name="MAR_DualArm">

  <!-- ============================================ -->
  <!-- MATERIALS DEFINITION                          -->
  <!-- ============================================ -->
  <material name="Grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="Orange">
    <color rgba="1.0 0.423529411765 0.0392156862745 1.0"/>
  </material>
  <material name="Blue">
    <color rgba="0.5 0.7 1.0 1.0"/>      
  </material>
  <material name="Red">
    <color rgba="1 0 0 1.0"/>      
  </material>
  <material name="Green">
    <color rgba="0.0 1.0 0.0 1.0"/>      
  </material>

  <!-- ============================================ -->
  <!-- BASE: SPACECRAFT (Torso MAR)                 -->
  <!-- ============================================ -->
  <link name="Spacecraft">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="200"/>
      <!-- Inertie d'un cube de 0.3m (comme papier Lutze) -->
      <inertia ixx="3.0" ixy="0" ixz="0" iyy="3.0" iyz="0" izz="3.0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
      <material name="Grey"/>
    </visual>
  </link>

  <!-- ============================================ -->
  <!-- BRAS GAUCHE (LEFT ARM) - 3 DOF               -->
  <!-- ============================================ -->
  
  <!-- Joint d'attache bras gauche -->
  <joint name="Spacecraft_Left_Arm" type="fixed">
    <parent link="Spacecraft"/>
    <child link="Left_Link_0"/>
    <origin rpy="0 0 0" xyz="0 0.3 0.25"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Link 0 gauche (base bras) -->
  <link name="Left_Link_0">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <mass value="5"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <geometry>
        <cylinder radius="0.05" length="0.25"/>
      </geometry>
      <material name="Grey"/>
    </visual>
  </link>

  <!-- Joint 1 gauche (azimut épaule) -->
  <joint name="Left_Joint_1" type="revolute">
    <parent link="Left_Link_0"/>
    <child link="Left_Link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 1 gauche -->
  <link name="Left_Link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <mass value="5"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry>
        <cylinder radius="0.05" length="0.2"/>
      </geometry>
      <material name="Blue"/>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.1"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- Joint 2 gauche (élévation épaule) -->
  <joint name="Left_Joint_2" type="revolute">
    <parent link="Left_Link_1"/>
    <child link="Left_Link_2"/>
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 2 gauche -->
  <link name="Left_Link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <geometry>
        <cylinder radius="0.05" length="0.75"/>
      </geometry>
      <material name="Blue"/>
    </visual>
    <visual>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- Joint 3 gauche (coude) -->
  <joint name="Left_Joint_3" type="revolute">
    <parent link="Left_Link_2"/>
    <child link="Left_Link_3"/>
    <origin rpy="0 0 0" xyz="0 0 0.75"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 3 gauche -->
  <link name="Left_Link_3">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <geometry>
        <cylinder radius="0.05" length="0.75"/>
      </geometry>
      <material name="Blue"/>
    </visual>
    <visual>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- End-Effector gauche -->
  <joint name="Left_Joint_EE" type="fixed">
    <parent link="Left_Link_3"/>
    <child link="Left_Link_EE"/>
    <origin rpy="0 0 0" xyz="0 0 0.75"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="Left_Link_EE">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="Red"/>
    </visual>
  </link>

  <!-- ============================================ -->
  <!-- BRAS DROIT (RIGHT ARM) - 3 DOF (IDENTIQUE)  -->
  <!-- ============================================ -->
  
  <!-- Joint d'attache bras droit -->
  <joint name="Spacecraft_Right_Arm" type="fixed">
    <parent link="Spacecraft"/>
    <child link="Right_Link_0"/>
    <origin rpy="0 0 0" xyz="0 -0.3 0.25"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Link 0 droit (base bras) -->
  <link name="Right_Link_0">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <mass value="5"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <geometry>
        <cylinder radius="0.05" length="0.25"/>
      </geometry>
      <material name="Grey"/>
    </visual>
  </link>

  <!-- Joint 1 droit (azimut épaule) -->
  <joint name="Right_Joint_1" type="revolute">
    <parent link="Right_Link_0"/>
    <child link="Right_Link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.25"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 1 droit -->
  <link name="Right_Link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <mass value="5"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry>
        <cylinder radius="0.05" length="0.2"/>
      </geometry>
      <material name="Green"/>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.1"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- Joint 2 droit (élévation épaule) -->
  <joint name="Right_Joint_2" type="revolute">
    <parent link="Right_Link_1"/>
    <child link="Right_Link_2"/>
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 2 droit -->
  <link name="Right_Link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <geometry>
        <cylinder radius="0.05" length="0.75"/>
      </geometry>
      <material name="Green"/>
    </visual>
    <visual>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- Joint 3 droit (coude) -->
  <joint name="Right_Joint_3" type="revolute">
    <parent link="Right_Link_2"/>
    <child link="Right_Link_3"/>
    <origin rpy="0 0 0" xyz="0 0 0.75"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <!-- Link 3 droit -->
  <link name="Right_Link_3">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.375"/>
      <geometry>
        <cylinder radius="0.05" length="0.75"/>
      </geometry>
      <material name="Green"/>
    </visual>
    <visual>
      <origin rpy="0 1.5708 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
      <material name="Orange"/>
    </visual>
  </link>

  <!-- End-Effector droit -->
  <joint name="Right_Joint_EE" type="fixed">
    <parent link="Right_Link_3"/>
    <child link="Right_Link_EE"/>
    <origin rpy="0 0 0" xyz="0 0 0.75"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="Right_Link_EE">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="Red"/>
    </visual>
  </link>
  
</robot>